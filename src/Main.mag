Main subclass: Object

  classMethod: start [
    'Dorado Main.start running' println.
    DoradoDisplay transcript: 'Hello from Maggie!'.
    DoradoDisplay transcript: 'VM is connected to the display.'.
    ('Window count: ', DoradoDisplay windowCount printString) println.
    DoradoDisplay newWindow: 'Workspace'.
    ('Window count after: ', DoradoDisplay windowCount printString) println.
  ]
